{
  "name": "@midnight-ntwrk/example-bboard",
  "version": "1.0.0",
  "author": "IOG",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.11.1"
  },
  "scripts": {
    "postinstall": "patch-package --patch-dir infra/patches",
    "setup": "./setup.sh",
    "doctor": "node infra/scripts/doctor.mjs",
    "verify": "npm run doctor",
    "dev": "npm run dev -w @midnight-ntwrk/bboard-web",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean -w @midnight-ntwrk/bboard-web --if-present && rm -rf node_modules cli/node_modules web/node_modules api/node_modules contracts/node_modules cli/dist api/dist contracts/dist web/.next",
    "build:contract": "npm run compact -w @midnight-ntwrk/bboard-contract && npm run build -w @midnight-ntwrk/bboard-contract",
    "build:api": "npm run build -w @midnight-ntwrk/bboard-api",
    "build:cli": "npm run build -w @midnight-ntwrk/bboard-cli",
    "build:all": "npm run build:contract && npm run build:api && npm run build:cli",
    "contracts:build": "npm run build:contract",
    "contracts:test": "npm run test -w @midnight-ntwrk/bboard-contract",
    "contracts:deploy": "npm run deploy --",
    "deploy": "node infra/scripts/deploy/deploy.mjs",
    "wallet:reset": "npm run wallet:reset -w @midnight-ntwrk/bboard-cli --",
    "docker:start": "node infra/scripts/docker/start.mjs",
    "docker:stop": "node infra/scripts/docker/stop.mjs",
    "docker:reset": "node infra/scripts/docker/reset.mjs",
    "blockchain:start": "node infra/scripts/blockchain/start.mjs",
    "blockchain:stop": "node infra/scripts/blockchain/stop.mjs",
    "blockchain:reset": "node infra/scripts/blockchain/reset.mjs"
  },
  "workspaces": {
    "packages": [
      "cli",
      "web",
      "api",
      "contracts"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/midnight-js-contracts": "4.1.1",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-network-id": "4.1.1",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "4.1.1",
    "@midnight-ntwrk/midnight-js-protocol": "4.1.1",
    "@midnight-ntwrk/midnight-js-types": "4.1.1",
    "@midnight-ntwrk/midnight-js-utils": "4.1.1",
    "@midnight-ntwrk/testkit-js": "4.1.1",
    "@midnight-ntwrk/wallet-sdk": "1.0.0",
    "axios": "^1.17.0",
    "buffer": "^6.0.3",
    "fp-ts": "^2.16.11",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rxjs": "^7.8.2",
    "semver": "^7.8.4",
    "testcontainers": "^12.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@types/babel__core": "^7.20.5",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "http-server": "^14.1.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.4",
    "rollup": "^4.62.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.14",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
