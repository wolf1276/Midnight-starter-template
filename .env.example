# Root environment reference for the Midnight bboard monorepo.
#
# This file documents every environment variable used across workspaces. It is
# NOT loaded automatically — each workspace has its own scoped env file:
#   web/.env.local        <- copy from web/.env.example (done automatically by ./setup.sh)
#
# The CLI/deploy pipeline (scripts/deploy/deploy.mjs, cli/src/launcher/*) does not
# use env files: network selection is a CLI flag (--network preview|preprod), and
# indexer/node/proof-server endpoints are hardcoded per network in cli/src/config.ts
# since they rarely change. Deployed contract addresses are written to
# deployment.json at the repo root after a successful `npm run contracts:deploy`.

# --- web/.env.local ----------------------------------------------------------

# The Midnight network the frontend talks to. Must match the network the
# user's wallet extension (Lace/1AM) is configured for.
# One of: undeployed | devnet | testnet | preview | preprod | mainnet
NEXT_PUBLIC_NETWORK_ID=preprod

# Log verbosity for the in-browser pino logger.
# One of: fatal | error | warn | info | debug | trace | silent
NEXT_PUBLIC_LOGGING_LEVEL=info
