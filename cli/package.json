{
  "name": "@midnight-ntwrk/bboard-cli",
  "version": "0.1.0",
  "author": "IOG",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -R ../contracts/src/managed dist/contracts/src/managed",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "lint": "eslint src",
    "prepack": "npm run build",
    "standalone": "node --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/standalone.ts",
    "preview-remote": "node --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/preview.ts",
    "preprod-remote": "node --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/preprod.ts",
    "wallet:reset": "node --experimental-specifier-resolution=node --loader ts-node/esm src/launcher/wallet-reset.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.3.0",
    "vitest": "^3.2.7"
  }
}
