{
  "name": "create-midnight",
  "version": "1.3.0",
  "description": "Scaffold a production-ready Midnight DApp in seconds.",
  "keywords": [
    "midnight",
    "create-midnight",
    "scaffold",
    "cli",
    "dapp",
    "zk",
    "blockchain"
  ],
  "license": "MIT",
  "author": "Midnight Starter Template contributors",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "bin": {
    "create-midnight": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "log-symbols": "^7.0.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "tar": "^7.4.3",
    "validate-npm-package-name": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/validate-npm-package-name": "^4.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wolf1276/Midnight-starter-template.git",
    "directory": "create-midnight"
  },
  "bugs": {
    "url": "https://github.com/wolf1276/Midnight-starter-template/issues"
  },
  "homepage": "https://github.com/wolf1276/Midnight-starter-template/tree/main/create-midnight#readme"
}
