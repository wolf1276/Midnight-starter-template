# Copy this file to .env.local and adjust as needed:
#   cp .env.example .env.local

# The Midnight network this app talks to. Must match the network the user's
# Lace/1AM wallet extension is configured for, or wallet connection will fail.
# One of: undeployed | devnet | testnet | preview | preprod | mainnet
NEXT_PUBLIC_NETWORK_ID=preprod

# Log verbosity for the in-browser pino logger.
# One of: fatal | error | warn | info | debug | trace | silent
NEXT_PUBLIC_LOGGING_LEVEL=info

# Note: indexer, indexer-websocket and proof-server URIs are NOT configured here.
# They are supplied at runtime by the connected wallet extension via
# `connectedAPI.getConfiguration()` (see src/services/midnight/providers.ts),
# so the same build works unmodified against any network the wallet points to.
